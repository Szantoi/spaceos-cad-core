<UserControl x:Class="CabinetBilder.Adapter.AutoCAD.UI.SmartObjectPalette.SmartObjectPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CabinetBilder.Adapter.AutoCAD.UI.SmartObjectPalette"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="280"
             Background="#1E1E2E"
             FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <!-- Converters -->
        <local:BooleanToVisibilityConverter   x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- Colour palette -->
        <SolidColorBrush x:Key="SurfaceBrush"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceAltBrush"   Color="#2A2A3E"/>
        <SolidColorBrush x:Key="AccentBrush"        Color="#7AA2F7"/>
        <SolidColorBrush x:Key="AccentHoverBrush"   Color="#5E81C5"/>
        <SolidColorBrush x:Key="TextPrimary"        Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextMuted"          Color="#6C7086"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#313244"/>

        <!-- Button style -->
        <Style x:Key="PaletteButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid row style â€” modified rows get a tinted background -->
        <Style x:Key="ModifiedRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModified}" Value="True">
                    <Setter Property="Background" Value="#2D1F2E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- â”€â”€ Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Smart Object"
                               FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding ObjectHandle, StringFormat='Handle: {0}'}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               Margin="0,2,0,0"
                               Visibility="{Binding HasSmartObject, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="&#xE713;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        ToolTip="KatalĂłgus kezelĂ©se"
                        Style="{StaticResource PaletteButton}"
                        Background="Transparent"
                        Foreground="{StaticResource TextMuted}"
                        Padding="4"
                        VerticalAlignment="Top"
                        Command="{Binding ManageCatalogCommand}"/>
            </Grid>
        </Border>

        <!-- â”€â”€ No-object placeholder â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasSmartObject, Converter={StaticResource InvBoolToVis}}">
            <TextBlock Text="&#xE7C3;"
                       FontFamily="Segoe MDL2 Assets" FontSize="32"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="16,8,16,0"/>
        </StackPanel>

        <!-- â”€â”€ DataGrid â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Fields}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  Background="{StaticResource SurfaceBrush}"
                  RowBackground="{StaticResource SurfaceBrush}"
                  AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                  Foreground="{StaticResource TextPrimary}"
                  BorderThickness="0"
                  RowStyle="{StaticResource ModifiedRowStyle}"
                  Visibility="{Binding HasSmartObject, Converter={StaticResource BoolToVis}}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
                    <Setter Property="FontWeight"      Value="SemiBold"/>
                    <Setter Property="Padding"         Value="8,4"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="8,4"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"  Value="#2E3452"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Kulcs"
                                    Binding="{Binding Key, Mode=OneWay}"
                                    Width="110"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Padding"    Value="8,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Ă‰rtĂ©k" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- Regular TextBox for non-material fields -->
                                <TextBlock Text="{Binding Value}" 
                                           Padding="8,4"
                                           Visibility="{Binding IsMaterial, Converter={StaticResource InvBoolToVis}}"/>
                                
                                <!-- ComboBox for material fields -->
                                <ComboBox ItemsSource="{Binding PossibleValues}"
                                          SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Visibility="{Binding IsMaterial, Converter={StaticResource BoolToVis}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="{StaticResource TextPrimary}">
                                    <ComboBox.Resources>
                                        <!-- Customizing ComboBox to fit the Dark Theme -->
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- Editing TextBox for non-material fields -->
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="#2E3452"
                                         Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="{StaticResource AccentBrush}"
                                         Padding="6,3"
                                         Visibility="{Binding IsMaterial, Converter={StaticResource InvBoolToVis}}"/>

                                <!-- ComboBox is already interactive in CellTemplate usually, 
                                     but we define it here for consistency if needed. -->
                                <ComboBox ItemsSource="{Binding PossibleValues}"
                                          SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Visibility="{Binding IsMaterial, Converter={StaticResource BoolToVis}}"
                                          Background="#2E3452"
                                          Foreground="{StaticResource TextPrimary}"
                                          BorderBrush="{StaticResource AccentBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- â”€â”€ Footer: Status + Buttons â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="&#xE118;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Pull (FrissĂ­tĂ©s szerverrĹ‘l)"
                            Style="{StaticResource PaletteButton}"
                            Command="{Binding PullCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource TextPrimary}"
                            Margin="0,0,4,0"
                            Width="32"/>
                    <Button Content="&#xE11C;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Push (FeltĂ¶ltĂ©s szerverre)"
                            Style="{StaticResource PaletteButton}"
                            Command="{Binding PushCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource TextPrimary}"
                            Margin="0,0,4,0"
                            Width="32"/>
                    <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Refresh"
                            Style="{StaticResource PaletteButton}"
                            Command="{Binding RefreshCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource TextPrimary}"
                            Margin="0,0,6,0"
                            Width="32"/>
                    <Button Content="MentĂ©s"
                            Style="{StaticResource PaletteButton}"
                            Command="{Binding SaveCommand}"
                            Padding="12,4"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

